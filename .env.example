# Configuración de la Base de Datos (PostgreSQL)
# Si usas el docker-compose del proyecto, estos son los valores por defecto:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/pos_db?schema=public&connection_limit=50"

# Puerto en el que correrá la API (recomendado 3001 para evitar conflictos)
PORT=3001

# Configuración JWT
JWT_SECRET="super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="3600s"
