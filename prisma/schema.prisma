generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        Int       @id @default(autoincrement())
  firstName String?   @map("first_name") @db.VarChar(255)
  lastName  String?   @map("last_name") @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  address   String?   @db.VarChar(255)
  email     String?   @unique @db.VarChar(255)
  invoices  Invoice[]

  @@map("clients")
}

model User {
  id           Int          @id @default(autoincrement())
  username     String       @unique @db.VarChar(50)
  name         String       @db.VarChar(100)
  lastName     String       @db.VarChar(100)
  cedula       String?      @db.VarChar(20)
  email        String       @unique @db.VarChar(255)
  password     String       @db.VarChar(255)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  roles        UserRole[]
  blockedUsers BlockedUser[]

  @@map("users")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique @map("name")
  description String?   @db.VarChar(255)
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId    Int     @map("user_id")
  roleId    Int     @map("role_id")
  user      User    @relation(fields: [userId], references: [id])
  role      Role    @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model BlockedUser {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique @map("user_id")
  failedAttempts  Int       @default(0) @map("failed_attempts")
  blockedAt       DateTime? @map("blocked_at") @db.Timestamp(6)
  user            User      @relation(fields: [userId], references: [id])

  @@map("blocked_users")
}

model Product {
  id              Int             @id @default(autoincrement())
  name            String?         @unique @db.VarChar(255)
  price           Decimal?        @db.Decimal(12, 2)
  stock           Int?
  version         Int             @default(0)
  productTaxes    ProductTax[]
  invoiceDetails InvoiceDetail[]

  @@map("products")
}

model ProductTax {
  id       Int     @id @default(autoincrement())
  productId Int    @map("product_id")
  taxId    Int     @map("tax_id")
  product  Product @relation(fields: [productId], references: [id])
  tax      Tax     @relation(fields: [taxId], references: [id])

  @@map("product_taxes")
}

model Tax {
  id              Int                @id @default(autoincrement())
  name            String?            @unique @db.VarChar(255)
  currentRate     Decimal?           @map("current_rate") @db.Decimal(5, 2)
  productTaxes    ProductTax[]
  detailTaxes    InvoiceDetailTax[]

  @@map("taxes")
}

model Invoice {
  id               Int             @id @default(autoincrement())
  clientId         Int?            @map("client_id")
  issueDate        DateTime?       @default(now()) @map("issue_date") @db.Timestamp(6)
  subtotalSnapshot Decimal?        @map("subtotal_snapshot") @db.Decimal(12, 2)
  taxTotalSnapshot Decimal?        @map("tax_total_snapshot") @db.Decimal(12, 2)
  totalSnapshot    Decimal?        @map("total_snapshot") @db.Decimal(12, 2)
  transactionId    String?         @map("transaction_id") @db.VarChar(255)
  client           Client?         @relation(fields: [clientId], references: [id])
  details          InvoiceDetail[]

  @@map("invoices")
}

model InvoiceDetail {
  id                Int                @id @default(autoincrement())
  invoiceId         Int?               @map("invoice_id")
  productId         Int?               @map("product_id")
  productName       String?            @map("product_name") @db.VarChar(255)
  quantity          Int?
  unitPriceSnapshot Decimal?           @map("unit_price_snapshot") @db.Decimal(12, 2)
  invoice           Invoice?           @relation(fields: [invoiceId], references: [id])
  product           Product?           @relation(fields: [productId], references: [id])
  detailTaxes      InvoiceDetailTax[]

  @@map("invoice_details")
}

model InvoiceDetailTax {
  id                       Int            @id @default(autoincrement())
  detailId                 Int?           @map("detail_id")
  taxId                    Int?           @map("tax_id")
  rateSnapshot             Decimal?       @map("rate_snapshot") @db.Decimal(5, 2)
  calculatedAmountSnapshot Decimal?       @map("calculated_amount_snapshot") @db.Decimal(12, 2)
  invoiceDetail           InvoiceDetail? @relation(fields: [detailId], references: [id])
  tax                     Tax?           @relation(fields: [taxId], references: [id])

  @@map("invoice_detail_taxes")
}
